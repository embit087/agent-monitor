{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Agent Monitor",
  "version": "0.1.0",
  "identifier": "com.objsinc.agm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Monitor",
        "label": "main",
        "width": 560,
        "height": 640,
        "minWidth": 180,
        "minHeight": 520,
        "resizable": true,
        "decorations": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
